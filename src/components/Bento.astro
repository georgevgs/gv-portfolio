---
import "../styles/bento.css";

const techStack = [
  "React", "TypeScript", "Node.js", "Angular",
  "Tailwind", "REST APIs", "CI/CD",
  "Jest", "Cypress", "MySQL", "MongoDB",
];

const works = [
  { title: "Karadimas",           href: "/work/karadimas",           img: "/assets/karadimas.webp",           accent: "#ff7900" },
  { title: "Glyfada Rent a Bike", href: "/work/glyfada-rent-a-bike", img: "/assets/glyfada-rent-a-bike.webp", accent: "#ff3885" },
  { title: "The Kitchen Studio",  href: "/work/the-kitchen-studio",  img: "/assets/the-kitchen-studio.webp",  accent: "#ff7900" },
  { title: "Budgard",              href: "/work/budgard",              img: "/assets/budgard.webp",              accent: "#ff3885" },
  { title: "Low & Flow",          href: "/work/low-and-flow",        img: "/assets/low-and-flow.webp",        accent: "#00a800" },
];
---

<section class="bento">
  <div class="bento-grid">

    <!-- Hero -->
    <a href="/about" class="cell cell-white cell-hover b-hero">
      <div class="hero-content">
        <img src="/assets/gv-dev-sticker.webp" alt="George Vagdas" class="hero-avatar" />
        <div class="hero-text">
          <p class="hero-greeting">Hello, I'm</p>
          <h1 class="hero-name">George Vagdas</h1>
          <p class="hero-desc">
            Full-Stack Developer from Greece&nbsp;🇬🇷, based in 📍&nbsp;Athens.
            Specializing in React &amp; TypeScript — building performant, scalable web apps with reusable components and sharp UI.
          </p>
        </div>
      </div>
      <div class="hero-arrow">↗</div>
    </a>

    <!-- Tech Stack -->
    <div class="cell cell-orange b-stack">
      <h2 class="stack-title">Tech Stack</h2>
      <div class="stack-chips">
        {techStack.map((t) => <span class="stack-chip">{t}</span>)}
      </div>
    </div>

    <!-- LinkedIn -->
    <a href="https://linkedin.com/in/gvagdas" target="_blank" rel="noopener" class="cell cell-blue cell-hover b-li social-cell">
      <img src="/assets/svg/linkedin-logo.svg" alt="LinkedIn" width="48" height="48" class="social-icon" />
      <span class="social-handle">in/gvagdas</span>
    </a>

    <!-- GitHub -->
    <a href="https://github.com/georgevgs" target="_blank" rel="noopener" class="cell cell-dark cell-hover b-gh social-cell">
      <img src="/assets/svg/github-logo.svg" alt="GitHub" width="48" height="48" class="social-icon" />
      <span class="social-handle">georgevgs</span>
    </a>

    <!-- Work cells — full-bleed image with colored gradient overlay -->
    {works.map((w, i) => (
      <a
        href={w.href}
        class={`cell cell-hover b-w${i} work-cell`}
        style={`--accent: ${w.accent};`}
      >
        <img src={w.img} alt={w.title} class="work-bg" loading="lazy" />
        <div class="work-gradient"></div>
        <div class="work-bottom">
          <h2 class="work-title">{w.title}</h2>
          <span class="work-arrow">↗</span>
        </div>
      </a>
    ))}

    <!-- Contact -->
    <div class="cell cell-green b-contact">
      <h2 class="contact-title">Let's Work Together</h2>
      <p class="contact-sub">Have a project in mind? I'd love to hear about it.</p>
      <a href="mailto:dev@vagdas.eu" class="btn btn-white">Get in Touch</a>
    </div>

  </div>
</section>
