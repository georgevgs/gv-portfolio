---
import MainHead from "../components/MainHead.astro";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import type { Project } from "../types";
import "../styles/project.css";

const {
  title,
  description,
  tags,
  img,
  parentURL,
  techStack,
  features,
  website,
} = Astro.props as Project;
---

<html lang="en">
  <head>
    <MainHead title={title} description={description} />
  </head>
  <body>
    <Nav />
    <main class="project-wrapper">
      <!-- Hero -->
      <header class="project-hero" style={`background-image:url(${img})`}>
        <div class="project-hero-overlay"></div>
        <div class="project-hero-content">
          <div class="project-tags">
            {tags.map((t) => <span class="project-tag">{t}</span>)}
          </div>
          <h1 class="project-title">{title}</h1>
          <p class="project-desc">{description}</p>
        </div>
      </header>

      <!-- Details -->
      <div class="project-details">
        <div class="project-card">
          <h3 class="project-card-label">Tech Stack</h3>
          <div class="project-chips">
            {techStack.map((item) => <span class="project-chip">{item}</span>)}
          </div>
        </div>

        <div class="project-card">
          <h3 class="project-card-label">Features</h3>
          <ul class="project-features">
            {features.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        {website && website.url && (
          <div class="project-card">
            <h3 class="project-card-label">Website</h3>
            <a href={website.url} target="_blank" rel="noopener" class="project-link">
              {website.displayText} <span class="project-link-arrow">↗</span>
            </a>
          </div>
        )}

        <a href="/" class="project-back">← Back to Home</a>
      </div>
    </main>
    <Footer />
  </body>
</html>
