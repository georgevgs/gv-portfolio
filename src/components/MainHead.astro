---
import "../styles/global.css";
const {
  title = "George Vagdas — Full-Stack Developer",
  description = "George Vagdas — Full-Stack Developer specializing in React, TypeScript & Node.js. Building scalable web applications in Athens, Greece.",
} = Astro.props;
---

<meta charset="UTF-8" />
<meta name="description" property="og:description" content={description} />
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
<title>{title}</title>

<link rel="icon" type="image/svg+xml" href="/favicon.webp" />
<!-- Preload for Silka Regular font -->
<link
  rel="preload"
  href="/fonts/silka/silka-regular-webfont.woff2"
  as="font"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/silka/silka-regular-webfont.woff"
  as="font"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/silka/silka-regular-webfont.ttf"
  as="font"
  crossorigin
/>

<!-- Preload for Moranga Bold font -->
<link
  rel="preload"
  href="/fonts/moranga/moranga-bold.otf"
  as="font"
  crossorigin
/>

<script src="https://kit.fontawesome.com/a0c9def029.js" crossorigin="anonymous"
></script>
