---
import Project from "../../layouts/project.astro";

const techStack = [
  "TypeScript",
  "Vite",
  "Tailwind CSS",
  "Drizzle ORM",
  "Deployed on Vercel",
];

const features = [
  "Browse available bicycles with photos and pricing.",
  "Online booking engine for reservations.",
  "Contact form for customer inquiries.",
  "Dark / light theme toggle.",
  "Responsive design optimized for mobile visitors.",
];

const website = {
  url: "https://glyfadarentabike.gr",
  displayText: "glyfadarentabike.gr",
};
---

<Project
  title="Glyfada Rent a Bike"
  description="A bicycle rental website for a shop in Glyfada, Greece. Features an online booking engine and theme toggle."
  tags={["typescript", "vite", "tailwind", "drizzle"]}
  img="/assets/glyfada-rent-a-bike.webp"
  parentURL="/work"
  techStack={techStack}
  features={features}
  website={website}
/>
