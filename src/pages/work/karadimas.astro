---
import Project from "../../layouts/project.astro";

const techStack = [
  "Astro 5",
  "Tailwind CSS",
  "Flowbite",
  "Cloudinary",
  "Formspree",
  "Vercel Analytics",
  "Deployed on Vercel",
];

const features = [
  "Product categories: bath fixtures, tiles, and showroom highlights.",
  "Image carousels powered by Flowbite for completed projects.",
  "Images hosted on Cloudinary for optimized delivery.",
  "Contact form via Formspree for lead capture.",
  "Security headers configured via vercel.json.",
  "Statically generated for fast load times and strong SEO.",
];

const website = {
  url: "https://ikaradimas.gr",
  displayText: "ikaradimas.gr",
};
---

<Project
  title="Karadimas"
  description="A modern website for a bath and tiles shop in Glyfada, Greece. Built with Astro and Tailwind, with Cloudinary-hosted imagery."
  tags={["astro", "tailwind", "cloudinary", "vercel"]}
  img="/assets/karadimas.webp"
  parentURL="/work"
  techStack={techStack}
  features={features}
  website={website}
/>
