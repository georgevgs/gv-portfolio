---
import Project from "../../layouts/project.astro";

const techStack = [
  "WooCommerce",
  "WordPress",
  "PHP",
  "MySQL",
  "Redis",
  "LiteSpeed",
  "Hosted on Hetzner",
];

const features = [
  "Full product catalog with categories and filtering.",
  "Shopping cart with shipping and tax calculation.",
  "Integrated payment gateway for online orders.",
  "Customer account management and order history.",
  "Admin panel for inventory and order management.",
];

const website = {
  url: "https://lowandflow.gr",
  displayText: "lowandflow.gr",
};
---

<Project
  title="Low and Flow"
  description="An e-commerce store for a local bike shop, powered by WooCommerce with Redis caching and LiteSpeed, hosted on Hetzner."
  tags={["ecommerce", "woocommerce", "php", "redis"]}
  img="/assets/low-and-flow.webp"
  parentURL="/work"
  techStack={techStack}
  features={features}
  website={website}
/>
