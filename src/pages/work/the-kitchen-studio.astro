---
import Project from "../../layouts/project.astro";

const techStack = [
  "Astro 5",
  "Tailwind CSS",
  "astro-i18next",
  "Embla Carousel",
  "MDX Blog",
  "Deployed on Vercel",
];

const features = [
  "Bilingual site — Greek (default) and English with i18n routing.",
  "Product categories: kitchens, bathrooms, doors, wardrobes, tiles, and more.",
  "Image carousels with autoplay for project showcases.",
  "Blog section with MDX-powered posts.",
  "Showroom and contact pages for lead generation.",
  "Statically generated for fast load times and SEO.",
];

const website = {
  url: "https://thekitchenstudio.gr",
  displayText: "thekitchenstudio.gr",
};
---

<Project
  title="The Kitchen Studio"
  description="A bilingual website for a custom kitchen furniture studio in Glyfada, Greece. Statically generated with Astro and deployed on Vercel."
  tags={["astro", "tailwind", "i18n", "vercel"]}
  img="/assets/the-kitchen-studio.webp"
  parentURL="/work"
  techStack={techStack}
  features={features}
  website={website}
/>
